# Local developer secrets.
# Copy this file to .env.local and replace placeholders with real keys.
# Do not commit .env.local.

# Groq ASR for short-drama transcription.
GROQ_API_KEY=gsk_your_key_here

# Optional model defaults used by short-drama scripts.
GROQ_ASR_MODEL=whisper-large-v3-turbo

# Optional remote LLM providers used by the desktop prototype.
OPENAI_API_KEY=sk_your_key_here
DEEPSEEK_API_KEY=sk_your_key_here
