{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Writer's Living Room",
  "version": "0.0.0",
  "identifier": "studio.twlr.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "The Writer's Living Room",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
