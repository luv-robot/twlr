{
  "name": "twlr",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @twlr/desktop",
    "desktop": "npm run tauri -w @twlr/desktop",
    "build": "npm run build --workspaces",
    "typecheck": "tsc --noEmit",
    "short-drama:apply-output": "node scripts/short-drama/apply-output.mjs",
    "short-drama:audit-case": "node scripts/short-drama/audit-case.mjs",
    "short-drama:build-correction-sheet": "node scripts/short-drama/build-correction-sheet.mjs",
    "short-drama:build-prompt": "node scripts/short-drama/build-prompt.mjs",
    "short-drama:build-scene-map": "node scripts/short-drama/build-scene-map.mjs",
    "short-drama:check-groq": "node scripts/short-drama/check-groq.mjs",
    "short-drama:create-case": "node scripts/short-drama/create-case.mjs",
    "short-drama:extract-audio-segments": "node scripts/short-drama/extract-audio-segments.mjs",
    "short-drama:extract-keyframes": "node scripts/short-drama/extract-keyframes.mjs",
    "short-drama:import-transcript": "node scripts/short-drama/import-transcript.mjs",
    "short-drama:index-cases": "node scripts/short-drama/index-cases.mjs",
    "short-drama:lint-report": "node scripts/short-drama/lint-report.mjs",
    "short-drama:run-case-review": "node scripts/short-drama/run-case-review.mjs",
    "short-drama:transcribe-groq": "node scripts/short-drama/transcribe-groq.mjs",
    "short-drama:validate-case": "node scripts/short-drama/validate-case.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
